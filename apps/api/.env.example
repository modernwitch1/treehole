# ===== App =====
NODE_ENV=development
APP_PORT=3000
APP_HOST=0.0.0.0
APP_BASE_URL=http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3001
MERCHANT_ORIGIN=http://localhost:3003
ADMIN_ORIGIN=http://localhost:3002
ALLOWED_EMAIL_DOMAIN=pop.zjgsu.edu.cn

# ===== Data retention =====
# Chatroom records remain traceable for this many days from room creation. Allowed: 30-3650.
# Rooms or messages under legal hold are not automatically deleted.
CHATROOM_RETENTION_DAYS=180

# ===== Database =====
DATABASE_URL=postgresql://forum:forum_dev_password@localhost:5432/forum?schema=public

# ===== Redis =====
REDIS_URL=redis://localhost:6379

# ===== JWT =====
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_me_with_64_random_bytes_hex
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
ADMIN_TOTP_SECRET=

# ===== Anonymous secret (NEVER ROTATE in production) =====
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ANON_SECRET=replace_me_with_64_random_bytes_hex

# ===== AWS / S3 =====
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=local-dev-key
AWS_SECRET_ACCESS_KEY=local-dev-secret
S3_ENDPOINT=http://localhost:9000
S3_FORCE_PATH_STYLE=true
S3_UPLOADS_BUCKET=zjgsu-forum-uploads
S3_AVATARS_BUCKET=zjgsu-forum-avatars
# Legacy object URL compatibility only. New uploads return a controlled API URL
# (or an opaque registration upload reference), never an object-storage URL.
CDN_BASE_URL=http://localhost:9000

# ===== Email =====
# In development use maildev. In production, use one verified domain/sender
# and a single primary provider. Optional providers are only for outage
# failover; a quota/authentication/4xx error never switches to another provider.
MAIL_DRIVER=smtp
# Example production order: brevo,mailjet,smtp2go,resend
MAIL_PROVIDER_ORDER=
MAIL_FAILOVER_ON_TRANSIENT=true
MAIL_PROVIDER_TIMEOUT_MS=8000
MAIL_PROVIDER_FAILURE_THRESHOLD=3
MAIL_PROVIDER_COOLDOWN_SECONDS=120
MAIL_FROM=no-reply@forum.local
MAIL_FROM_NAME=浙工商树洞
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
# Resend
# RESEND_API_KEY=
# Brevo transactional API
# BREVO_API_KEY=
# BREVO_API_URL=https://api.brevo.com/v3/smtp/email
# Mailjet Send API v3.1
# MAILJET_API_KEY=
# MAILJET_API_SECRET=
# MAILJET_API_URL=https://api.mailjet.com/v3.1/send
# SMTP2GO API
# SMTP2GO_API_KEY=
# SMTP2GO_API_URL=https://api.smtp2go.com/v3/email/send
# Mailgun Send API
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=
# MAILGUN_API_BASE_URL=https://api.mailgun.net
# In production for AWS SES Tokyo:
# MAIL_DRIVER=ses
# AWS_REGION=ap-northeast-1
# MAIL_FROM=verified-sender@example.com
# Prefer an EC2 IAM role with ses:SendEmail/ses:SendRawEmail over static access keys.

# ===== Image moderation =====
# Set to "true" in production once AWS Rekognition is wired
IMAGE_MODERATION_ENABLED=false

# ===== Sentry (optional in dev) =====
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ===== Logging =====
LOG_LEVEL=debug
LOG_PRETTY=true

# ===== Rate limiting =====
RATE_LIMIT_TRUST_PROXY=false
