# ===== App =====
NODE_ENV=development
APP_PORT=3000
APP_HOST=0.0.0.0
APP_BASE_URL=http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3001
ADMIN_ORIGIN=http://localhost:3002
ALLOWED_EMAIL_DOMAIN=pop.zjgsu.edu.cn

# ===== Database =====
DATABASE_URL=postgresql://forum:forum_dev_password@localhost:5432/forum?schema=public

# ===== Redis =====
REDIS_URL=redis://localhost:6379

# ===== JWT =====
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_me_with_64_random_bytes_hex
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
ADMIN_TOTP_SECRET=

# ===== Anonymous secret (NEVER ROTATE in production) =====
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ANON_SECRET=replace_me_with_64_random_bytes_hex

# ===== AWS / S3 =====
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=local-dev-key
AWS_SECRET_ACCESS_KEY=local-dev-secret
S3_ENDPOINT=http://localhost:9000
S3_FORCE_PATH_STYLE=true
S3_UPLOADS_BUCKET=zjgsu-forum-uploads
S3_AVATARS_BUCKET=zjgsu-forum-avatars
CDN_BASE_URL=http://localhost:9000

# ===== Email (SES; locally → maildev SMTP) =====
MAIL_DRIVER=smtp
MAIL_FROM=no-reply@forum.local
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
# In production for AWS SES Tokyo:
# MAIL_DRIVER=ses
# AWS_REGION=ap-northeast-1
# MAIL_FROM=verified-sender@example.com
# Prefer an EC2 IAM role with ses:SendEmail/ses:SendRawEmail over static access keys.

# ===== Image moderation =====
# Set to "true" in production once AWS Rekognition is wired
IMAGE_MODERATION_ENABLED=false

# ===== Sentry (optional in dev) =====
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ===== Logging =====
LOG_LEVEL=debug
LOG_PRETTY=true

# ===== Rate limiting =====
RATE_LIMIT_TRUST_PROXY=false
